# Скопируйте в .env и заполните значения

# База данных (SQLite для локальной разработки)
DATABASE_URL=sqlite:///./sellerpulse.db

# Секретный ключ JWT — сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Ключ шифрования WB-токенов — сгенерируйте: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=10080
FRONTEND_ORIGIN=http://localhost:5173
ADMIN_SECRET=change-admin-secret
ENABLE_SCHEDULER=true
RUN_SYNC_WORKER_IN_WEB=true
SENTRY_DSN=
